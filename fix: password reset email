import { initializeApp } from "firebase/app";
import { 
  getAuth, 
  createUserWithEmailAndPassword,
  signInWithEmailAndPassword,
  signOut, 
  onAuthStateChanged, 
  User,
  updateProfile,
  sendPasswordResetEmail
} from "firebase/auth";
import { getFirestore, doc, setDoc, getDoc } from "firebase/firestore";

const firebaseConfig = {
  apiKey: import.meta.env.VITE_FIREBASE_API_KEY,
  authDomain: `${import.meta.env.VITE_FIREBASE_PROJECT_ID}.firebaseapp.com`,
  projectId: import.meta.env.VITE_FIREBASE_PROJECT_ID,
  storageBucket: `${import.meta.env.VITE_FIREBASE_PROJECT_ID}.firebasestorage.app`,
  appId: import.meta.env.VITE_FIREBASE_APP_ID,
};

const app = initializeApp(firebaseConfig);
export const auth = getAuth(app);
export const db = getFirestore(app);

export interface UserProfile {
  uid: string;
  name: string;
  email: string;
  createdAt: Date;
}

const authListeners: Array<(user: UserProfile | null) => void> = [];

const convertFirebaseUser = (firebaseUser: User | null): UserProfile | null => {
  if (!firebaseUser) return null;
  return {
    uid: firebaseUser.uid,
    name: firebaseUser.displayName || firebaseUser.email?.split('@')[0] || 'Utente',
    email: firebaseUser.email || '',
    createdAt: new Date()
  };
};

const notifyAuthListeners = (user: UserProfile | null) => {
  if (user) {
    localStorage.setItem('humi_current_user', JSON.stringify(user));
  } else {
    localStorage.removeItem('humi_current_user');
  }
  authListeners.forEach(callback => callback(user));
};

let authInitialized = false;
const initializeAuthListener = () => {
  if (authInitialized) return;
  authInitialized = true;
  onAuthStateChanged(auth, (firebaseUser) => {
    const userProfile = convertFirebaseUser(firebaseUser);
    notifyAuthListeners(userProfile);
  });
};

export const signUpWithEmail = async (email: string, password: string, name: string) => {
  try {
    const userCredential = await createUserWithEmailAndPassword(auth, email, password);
    const user = userCredential.user;
    await updateProfile(user, { displayName: name });
    await setDoc(doc(db, 'users', user.uid), {
      name,
      email: user.email,
      createdAt: new Date()
    });
    return convertFirebaseUser(user)!;
  } catch (error: any) {
    console.error("Firebase signup error:", error);
    throw new Error(error.message || 'Registration failed');
  }
};

export const signInWithEmail = async (email: string, password: string) => {
  try {
    const userCredential = await signInWithEmailAndPassword(auth, email, password);
    return convertFirebaseUser(userCredential.user)!;
  } catch (error: any) {
    console.error("Firebase signin error:", error);
    throw new Error(error.message || 'Login failed');
  }
};

export const logOut = async () => {
  try {
    await signOut(auth);
  } catch (error: any) {
    console.error("Firebase logout error:", error);
    throw new Error(error.message || 'Logout failed');
  }
};

export const resetPassword = async (
  email: string,
  errorMessages?: {
    userNotFound?: string;
    invalidEmail?: string;
    tooManyRequests?: string;
    generic?: string;
  }
) => {
  const mapError = (error: any): string => {
    const code = error?.code ?? '';
    if (code === 'auth/user-not-found' || code === 'auth/invalid-credential') {
      return errorMessages?.userNotFound ?? 'Email not found. Please check the address.';
    }
    if (code === 'auth/invalid-email') {
      return errorMessages?.invalidEmail ?? 'Invalid email address.';
    }
    if (code === 'auth/too-many-requests') {
      return errorMessages?.tooManyRequests ?? 'Too many attempts. Please try again later.';
    }
    return errorMessages?.generic ?? 'Error sending recovery email. Please try again.';
  };

  try {
    await sendPasswordResetEmail(auth, email, {
      url: 'https://humi.store',
      handleCodeInApp: false,
    });
    return { success: true };
  } catch (firstError: any) {
    const code = firstError?.code ?? '';
    console.warn('Firebase reset (with URL):', code, firstError.message);
    if (code === 'auth/unauthorized-continue-uri' || code === 'auth/invalid-continue-uri') {
      try {
        await sendPasswordResetEmail(auth, email);
        return { success: true };
      } catch (fallbackError: any) {
        console.error('Firebase reset (fallback):', fallbackError.code, fallbackError.message);
        throw new Error(mapError(fallbackError));
      }
    }
    throw new Error(mapError(firstError));
  }
};

export const onAuthStateChange = (callback: (user: UserProfile | null) => void) => {
  initializeAuthListener();
  authListeners.push(callback);
  const currentUser = auth.currentUser;
  callback(convertFirebaseUser(currentUser));
  return () => {
    const index = authListeners.indexOf(callback);
    if (index > -1) {
      authListeners.splice(index, 1);
    }
  };
};
