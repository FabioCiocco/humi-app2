interface GeolocationData {
  latitude: number;
  longitude: number;
  timezone: string;
  country: string;
  countryCode?: string;
  city?: string;
}

interface TimeBasedGreeting {
  greeting: string;
  icon: string;
}

export class GeolocationService {
  private static instance: GeolocationService;
  private cachedLocation: GeolocationData | null = null;
  private readonly CACHE_DURATION = 24 * 60 * 60 * 1000;

  static getInstance(): GeolocationService {
    if (!GeolocationService.instance) {
      GeolocationService.instance = new GeolocationService();
    }
    return GeolocationService.instance;
  }

  async getCurrentLocation(): Promise<GeolocationData | null> {
    const cached = this.getCachedLocation();
    if (cached) return cached;

    try {
      const position = await this.getBrowserLocation();
      if (position) {
        const locationData = await this.getLocationDetails(position.coords.latitude, position.coords.longitude);
        this.cacheLocation(locationData);
        return locationData;
      }
    } catch (error) {
      console.log('Browser geolocation not available, using IP-based detection');
    }

    try {
      const locationData = await this.getIPLocation();
      this.cacheLocation(locationData);
      return locationData;
    } catch (error) {
      console.error('Failed to get location:', error);
      return null;
    }
  }

  private getBrowserLocation(): Promise<GeolocationPosition | null> {
    return new Promise((resolve) => {
      if (!navigator.geolocation) { resolve(null); return; }
      navigator.geolocation.getCurrentPosition(
        (position) => resolve(position),
        () => resolve(null),
        { timeout: 10000, enableHighAccuracy: false }
      );
    });
  }

  private async getLocationDetails(lat: number, lon: number): Promise<GeolocationData> {
    try {
      const response = await fetch(`https://api.ipgeolocation.io/timezone?apiKey=free&lat=${lat}&long=${lon}`);
      if (response.ok) {
        const data = await response.json();
        return {
          latitude: lat,
          longitude: lon,
          timezone: data.timezone || Intl.DateTimeFormat().resolvedOptions().timeZone,
          country: data.country_name || 'Unknown',
          city: data.city
        };
      }
    } catch (error) {
      console.log('Timezone API failed, using browser timezone');
    }
    return {
      latitude: lat,
      longitude: lon,
      timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
      country: 'Unknown'
    };
  }

  private async getIPLocation(): Promise<GeolocationData> {
    const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
    try {
      const response = await fetch('https://ipapi.co/json/');
      if (response.ok) {
        const data = await response.json();
        return {
          latitude: data.latitude || 0,
          longitude: data.longitude || 0,
          timezone: data.timezone || timezone,
          country: data.country_name || 'Unknown',
          countryCode: data.country_code || '',
          city: data.city
        };
      }
    } catch (error) {
      console.log('IP geolocation failed, using browser timezone only');
    }
    return { latitude: 0, longitude: 0, timezone, country: 'Unknown', countryCode: '' };
  }

  getTimeBasedGreeting(location?: GeolocationData | null): TimeBasedGreeting {
    const now = new Date();
    let hour: number;
    if (location?.timezone) {
      try {
        const timeInTimezone = new Date(now.toLocaleString("en-US", { timeZone: location.timezone }));
        hour = timeInTimezone.getHours();
      } catch (error) {
        hour = now.getHours();
      }
    } else {
      hour = now.getHours();
    }
    if (hour >= 5 && hour < 12) return { greeting: 'goodMorning', icon: '🌅' };
    else if (hour >= 12 && hour < 17) return { greeting: 'goodAfternoon', icon: '☀️' };
    else if (hour >= 17 && hour < 22) return { greeting: 'goodEvening', icon: '🌆' };
    else return { greeting: 'goodEvening', icon: '🌙' };
  }

  private getCachedLocation(): GeolocationData | null {
    try {
      const cached = localStorage.getItem('humi_location');
      if (!cached) return null;
      const { data, timestamp } = JSON.parse(cached);
      if (Date.now() - timestamp > this.CACHE_DURATION) {
        localStorage.removeItem('humi_location');
        return null;
      }
      return data;
    } catch (error) {
      return null;
    }
  }

  private cacheLocation(location: GeolocationData): void {
    try {
      localStorage.setItem('humi_location', JSON.stringify({ data: location, timestamp: Date.now() }));
    } catch (error) {
      console.log('Failed to cache location');
    }
  }

  getLocalTime(location?: GeolocationData | null): string {
    const now = new Date();
    if (location?.timezone) {
      try {
        return now.toLocaleTimeString('en-US', { timeZone: location.timezone, hour: '2-digit', minute: '2-digit', hour12: true });
      } catch (error) {
        return now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });
      }
    }
    return now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });
  }
}

export const geolocationService = GeolocationService.getInstance();
